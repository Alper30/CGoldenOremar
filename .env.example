# Supabase — proje ayarları > API
# URL ve publishable (anon) anahtar herkese açık katalog okuması için yeterlidir (RLS public-select).
NEXT_PUBLIC_SUPABASE_URL=https://<proje-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service-role anahtarı — SADECE sunucu. RLS'i atlar; Stripe webhook'u siparişi
# ödendi işaretlerken kullanır. ASLA istemciye sızdırma (NEXT_PUBLIC değil).
SUPABASE_SERVICE_ROLE_KEY=service_role_xxx

# Stripe (TEST / sandbox)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe webhook imza sırrı (Stripe Dashboard > Developers > Webhooks).
# Endpoint: /api/stripe/webhook · olay: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Sunucu-içi ödeme onay sırrı (mark_order_paid RPC gate'i — private.app_config ile eşleşir)
PAYMENT_SECRET=<private.app_config.payment_secret değeriyle aynı>

# E-posta bildirimleri (Resend — https://resend.com). Anahtar yoksa gönderim
# sessizce atlanır (loglanır); site normal çalışmaya devam eder.
RESEND_API_KEY=re_xxx
# Gönderen adres — domain Resend'de doğrulanmış olmalı.
EMAIL_FROM="Golden Oremar <bildirim@goldenoremar.com>"

# E-postalardaki bağlantılar için mutlak site adresi (varsayılan: https://goldenoremar.com)
NEXT_PUBLIC_SITE_URL=https://goldenoremar.com

# Platform gelen kutusu — randevu talepleri ve operasyon bildirimleri buraya
# gönderilir (varsayılan: info@goldenoremar.com).
ADMIN_EMAIL=info@goldenoremar.com
